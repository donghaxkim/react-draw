{
  "name": "react-rewrite-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm build:shared && pnpm build:overlay && pnpm build:cli",
    "build:shared": "pnpm --filter @react-rewrite/shared build",
    "build:overlay": "pnpm --filter @react-rewrite/overlay build",
    "build:cli": "pnpm --filter react-rewrite-cli build",
    "dev": "pnpm build:overlay && pnpm --filter react-rewrite-cli dev",
    "typecheck": "pnpm build:shared && pnpm --filter react-rewrite-cli exec tsc --noEmit",
    "test": "pnpm --filter react-rewrite-cli test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
